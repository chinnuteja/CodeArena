# Production on AWS EC2 — copy to .env.production and fill secrets
# docker compose -f docker-compose.prod.yml --env-file .env.production up -d

NODE_ENV=production
PORT=4000

# Set by docker-compose.prod.yml service DNS (override only if using external Atlas/ElastiCache)
MONGO_URI=mongodb://mongodb:27017/online_judge
REDIS_URL=redis://redis:6379
REDIS_QUEUE_URL=redis://redis:6379

# REQUIRED — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7

# Must match nginx /api proxy (see deploy/nginx.conf)
REFRESH_COOKIE_PATH=/api/auth/refresh

ARGON2_MEMORY_COST=19456
LOG_LEVEL=info

ICPC_PENALTY_MINUTES=20
INVITE_TOKEN_TTL_DAYS=14
CONTEST_MAX_PROBLEMS=26

# Worker talks to host Docker daemon via mounted socket
DOCKER_SOCKET=/var/run/docker.sock
JUDGE_CONCURRENCY=4
SUBMISSION_MAX_SOURCE_BYTES=65536
SANDBOX_DEFAULT_TIME_MS=2000
SANDBOX_DEFAULT_MEMORY_MB=256
SANDBOX_PIDS_LIMIT=64
SANDBOX_OUTPUT_MAX_BYTES=65536
SANDBOX_CPUS=1
COMPILE_TIME_MS=10000
SSE_HEARTBEAT_MS=15000

# Persistent volumes (paths inside api/worker containers — mounted in compose)
STORAGE_PATH=/data/storage
JUDGE_WORKDIR=/data/workdir

# Behind nginx reverse proxy
TRUST_PROXY=true

# Same-origin via nginx — leave CORS unset. Only set if frontend is on a different origin:
# CORS_ORIGIN=https://app.example.com

# --- docker-compose.prod.yml image overrides (after ECR push) ---
# ECR_API_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/oj-api:latest
# ECR_WORKER_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/oj-worker:latest
# ECR_NGINX_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/oj-nginx:latest
# HTTP_PORT=80
# DOCKER_SOCKET_HOST=/var/run/docker.sock
# WORKER_USER=0
# WORKER_GROUP=0
