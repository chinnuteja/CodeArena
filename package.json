{
  "name": "online-judge",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "worker": "node dist/worker.js",
    "worker:dev": "tsx watch src/worker.ts",
    "build": "tsc",
    "build:images": "docker build -t oj-runtime-cpp:latest -f docker/cpp.Dockerfile . && docker build -t oj-runtime-python:latest -f docker/python.Dockerfile . && docker build -t oj-runtime-javascript:latest -f docker/node.Dockerfile . && docker build -t oj-runtime-java:latest -f docker/java.Dockerfile . && docker build -t oj-runtime-go:latest -f docker/go.Dockerfile .",
    "compose:prod": "docker compose -f docker-compose.prod.yml --env-file .env.production up -d",
    "compose:prod:down": "docker compose -f docker-compose.prod.yml --env-file .env.production down",
    "compose:prod:logs": "docker compose -f docker-compose.prod.yml --env-file .env.production logs -f",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "seed": "tsx seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "argon2": "^0.44.0",
    "bullmq": "^5.78.0",
    "dockerode": "^5.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "openai": "^6.45.0",
    "pino": "^10.3.1",
    "slugify": "^1.6.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "@types/semver": "^7.7.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.4.1",
    "ioredis-mock": "^8.13.1",
    "mongodb-memory-server": "^11.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "tslib": "^2.8.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
