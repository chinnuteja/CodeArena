# Local development — copy to .env
NODE_ENV=development
PORT=4000

# Databases (use docker-compose.yml for local Mongo + Redis)
MONGO_URI=mongodb://localhost:27017/online_judge
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_URL=redis://localhost:6379

# Auth — use long random strings in any shared environment
JWT_ACCESS_SECRET=change-me-access-min-10-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7
# Must match how the browser reaches /auth/refresh (Vite proxies /api → backend)
REFRESH_COOKIE_PATH=/api/auth/refresh

# Password hashing (Argon2)
ARGON2_MEMORY_COST=19456

# Logging
LOG_LEVEL=info

# Contests
ICPC_PENALTY_MINUTES=20
INVITE_TOKEN_TTL_DAYS=14
CONTEST_MAX_PROBLEMS=26

# Judge worker / sandbox
DOCKER_SOCKET=/var/run/docker.sock
JUDGE_CONCURRENCY=4
SUBMISSION_MAX_SOURCE_BYTES=65536
SANDBOX_DEFAULT_TIME_MS=2000
SANDBOX_DEFAULT_MEMORY_MB=256
SANDBOX_PIDS_LIMIT=64
SANDBOX_OUTPUT_MAX_BYTES=65536
SANDBOX_CPUS=1
COMPILE_TIME_MS=10000

# SSE
SSE_HEARTBEAT_MS=15000

# Local disk paths (relative to project root)
STORAGE_PATH=.tmp/storage
JUDGE_WORKDIR=.tmp/workdir

# Reverse proxy — off in local dev (Vite handles /api proxy)
TRUST_PROXY=false

# CORS — leave unset for same-origin; set comma-separated origins only if API and frontend are on different hosts
# CORS_ORIGIN=https://app.example.com
